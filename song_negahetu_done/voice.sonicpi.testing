use_bpm 90;

live_loop :negahe_tu do
  # kick + hat
  sample :bd_haus, amp: 1.2, rate: 1.0
  sleep 0.25
  sample :drum_cymbal_closed, amp: 0.4, rate: 1.3
  sleep 0.25
  
  # kick + hat
  sample :bd_haus, amp: 1.0, rate: 1.0
  sleep 0.25
  sample :drum_cymbal_closed, amp: 0.3, rate: 1.2
  sleep 0.25
  
  # snare + hat
  sample :drum_snare_hard, amp: 0.8, rate: 1.0
  sleep 0.25
  sample :drum_cymbal_closed, amp: 0.4, rate: 1.3
  sleep 0.25
  
  # kick + hat
  sample :bd_haus, amp: 1.0, rate: 1.0
  sleep 0.25
  sample :drum_cymbal_closed, amp: 0.3, rate: 1.2
  sleep 0.25
  
  # kick + hat
  sample :bd_haus, amp: 1.2, rate: 1.0
  sleep 0.25
  sample :drum_cymbal_closed, amp: 0.4, rate: 1.3
  sleep 0.25
  
  # kick + open hat (scatter)
  sample :bd_haus, amp: 1.0, rate: 1.0
  sleep 0.25
  sample :drum_cymbal_open, amp: 0.3, rate: 1.0
  sleep 0.25
  
  # snare + hat
  sample :drum_snare_hard, amp: 0.8, rate: 1.0
  sleep 0.25
  sample :drum_cymbal_closed, amp: 0.4, rate: 1.3
  sleep 0.25
  
  # kick + hat (return)
  sample :bd_haus, amp: 1.2, rate: 1.0
  sleep 0.25
  sample :drum_cymbal_closed, amp: 0.3, rate: 1.2
  sleep 0.25
end
